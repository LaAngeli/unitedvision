# Disable directory listing
Options -Indexes

<IfModule mod_rewrite.c>
    Options +FollowSymlinks
    RewriteEngine On

    # If request is already for /web, leave it unchanged.
    RewriteCond %{REQUEST_URI} ^/web/ [NC]
    RewriteRule ^ - [L]

    # Route everything else through /web so public_html can be project root.
    RewriteRule ^(.*)$ web/$1 [L]
</IfModule>

# Block direct web access to sensitive project folders/files
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(config|controllers|models|runtime|vendor|views|modules|migrations|commands|mail|tests|services|helpers|components|widgets)/ - [F,L,NC]
    RewriteRule ^(composer\.(json|lock)|yii|yii\.bat|requirements\.php)$ - [F,L,NC]
</IfModule>
